# ============================================================
# 校园二手交易平台 - 生产环境变量
# 1) 复制为 .env：cp .env.example .env
# 2) 改掉所有密码（特别是 MYSQL_ROOT_PASSWORD / JWT_SECRET）
# 3) .env 不要进 git
# ============================================================

# 应用版本（影响构建出来的镜像 tag，不影响代码）
APP_VERSION=1.0.0

# 对外端口
HTTP_PORT=80
HTTPS_PORT=443

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=123
MYSQL_DATABASE=campus

# ---------- Redis ----------
REDIS_PASSWORD=123321

# ---------- Nacos ----------
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
NACOS_NAMESPACE=
# Nacos 鉴权三件套（控制服务端到端鉴权），值越长越安全
NACOS_AUTH_KEY=campus-prod
NACOS_AUTH_VALUE=campus-prod
NACOS_AUTH_TOKEN=

# ---------- RabbitMQ ----------
RABBITMQ_USERNAME=campus
RABBITMQ_PASSWORD=123321

# ---------- Elasticsearch ----------
# 单机推荐 512m，业务量大可调到 1g/2g（注意还要给容器加 mem_limit）
ES_HEAP=512m

# ---------- JWT 共享密钥 ----------
# 需要至少 32 字节；用 `openssl rand -base64 48` 生成
JWT_SECRET=

# ---------- 阿里云 OSS（商品图片上传）----------

# 真实凭证必须只写到 .env(已在 .gitignore 中)
# 必须用 RAM 子账号,仅授予目标 bucket 的 PutObject/GetObject 权限
ALIYUN_OSS_ENABLED=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_AK=
ALIYUN_OSS_SECRET=
# 如配置 CDN/自定义域名,带 scheme 填这里;留空时返回 https://{bucket}.{endpoint-host}/{key}
ALIYUN_OSS_DOMAIN=
