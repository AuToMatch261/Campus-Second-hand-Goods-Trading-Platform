{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "ik_max": {
          "type": "ik_max_word"
        },
        "ik_smart": {
          "type": "ik_smart"
        }
      }
    }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "id": { "type": "long" },
      "sellerId": { "type": "long" },
      "title": {
        "type": "text",
        "analyzer": "ik_max",
        "search_analyzer": "ik_smart",
        "fields": {
          "keyword": { "type": "keyword", "ignore_above": 256 }
        }
      },
      "description": {
        "type": "text",
        "analyzer": "ik_max",
        "search_analyzer": "ik_smart"
      },
      "category": { "type": "integer" },
      "status": { "type": "integer" },
      "price": { "type": "scaled_float", "scaling_factor": 100 },
      "viewCount": { "type": "integer" },
      "images": { "type": "keyword", "index": false },
      "createdAt": { "type": "date" },
      "updatedAt": { "type": "date" }
    }
  }
}
